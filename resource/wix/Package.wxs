<?xml version="1.0" encoding="utf-8"?>
<!--
  Package.wxs — WiX v5+ translation of GpgFrontend.aip (Advanced Installer 23.7, "DefaultBuild").

  Payload root = the folder the AIP calls "GpgFrontend\" (its RootPath="." sits next to the .aip,
  i.e. D:\GpgFrontend Release). Build from this folder with:

      wix extension add -g WixToolset.UI.wixext/5.0.2
      wix extension add -g WixToolset.Util.wixext/5.0.2
      wix build -arch x64 -ext WixToolset.UI.wixext/5.0.2 -ext WixToolset.Util.wixext/5.0.2 `
        -o ..\dist\GpgFrontend.msi Package.wxs

  Extension versions must match the toolset major: an unpinned `wix extension add` grabs
  the latest (7.x), which a WiX 5 host cannot load.

  -arch x64 is required: the AIP's BuildComponent is MsiPackageType="x64".

  Deliberately NOT translated (Advanced Installer runtime plumbing with no MSI-visible effect):
  aicustact.dll and the AI_* custom actions (DpiContentScale, EnableDebugLog, ResolveKnownFolders,
  InstallModeCheck, PreserveInstallType, PrepareUpgrade, ShowLog), SET_TARGETDIR_TO_APPDIR, and
  SET_SHORTCUTDIR (the AIP defines SHORTCUTDIR but contains no Start-menu shortcut that uses it).
  AI_RESTORE_LOCATION / AI_STORE_LOCATION are reproduced below with native MSI idioms.
-->
<!--
  Overridable via `wix build -d name=value`. The <?ifndef?> guards keep the local
  defaults (a bare `wix build Package.wxs` from this folder) working, while CI passes
  the runner-specific version / payload root / icon path on the command line.
-->
<?ifndef ProductVersion ?>
<?define ProductVersion = "2.2.1" ?>
<?endif?>

<?ifndef PayloadDir ?>
<?define PayloadDir = "GpgFrontend" ?>
<?endif?>

<?ifndef IconSource ?>
<?define IconSource = "gpgfrontend.ico" ?>
<?endif?>

<!-- Folder holding banner.bmp / dialog.bmp — this folder, for a local build run from it. -->
<?ifndef BrandingDir ?>
<?define BrandingDir = "." ?>
<?endif?>

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!-- MsiPropsComponent: ProductName / Manufacturer / ProductVersion / UpgradeCode /
       ProductLanguage 1033. ProductCode is intentionally not pinned: like Advanced
       Installer, a fresh one is generated per build ("*" default) so MajorUpgrade works.
       ALLUSERS: the AIP's DefaultBuild overrides ALLUSERS to empty -> per-user package
       (SET_APPDIR: [AppDataFolder]\[ProductName]). Scope="perUser" reproduces that.
       InstallerVersion 450 = the AIP's SummInfoMetadata "Page Count:450". -->
  <Package
    Name="GpgFrontend"
    Manufacturer="Saturneric"
    Version="$(ProductVersion)"
    UpgradeCode="3c642b54-3921-43ce-b744-a2bf0b4fc309"
    Language="1033"
    Codepage="1252"
    InstallerVersion="450"
    Compressed="yes"
    Scope="perUser">

    <!-- MsiUpgradeComponent:
           row 1: 0.0.1 <= v < ProductVersion, Attributes 257 (min-inclusive + MigrateFeatures) -> OLDPRODUCTS
           row 2: v > ProductVersion, Attributes 2 (detect-only) -> AI_NEWERPRODUCTFOUND
         MsiCustActComponent AI_DOWNGRADE: Type 19 (error) when a newer product is found.
         AllowSameVersionUpgrades departs from the AIP deliberately: every nightly carries the
         same ProductVersion (2.2.1) but a fresh ProductCode, so without it each nightly is a
         *separate* product that installs over the previous one's files instead of replacing
         it, stacking entries in Add/Remove Programs and leaving two products owning the
         same paths under AppData. With it, RemoveExistingProducts clears the old install
         first and every write lands in a clean tree. -->
    <MajorUpgrade
      AllowDowngrades="no"
      AllowSameVersionUpgrades="yes"
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
      MigrateFeatures="yes"
      Schedule="afterInstallValidate" />

    <!-- MaximumUncompressedMediaSize overrides the 200 MB default: the payload (Qt closure +
         GnuPG + modules) is larger than that, so the default silently splits it across
         cab1/cab2/..., and a file landing on a media boundary is a known source of extraction
         failures mid-install. One cab for the whole package removes that variable. -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" MaximumUncompressedMediaSize="4096" />

    <!-- Close anything still holding a file in the install tree, otherwise MSI aborts with
         1310 ("Error writing to file ... verify that you have access to that directory")
         on reinstall/upgrade. Two families of holders:
           - GpgFrontend.exe itself (holds bin\*.dll, e.g. the Qt closure windeployqt drops
             there: libexpat-1.dll, libpng, libzstd, ...);
           - the GnuPG daemons under gnupg\, which deliberately outlive the GUI and keep
             running with the old binaries mapped.
         TerminateProcess=0 asks politely first (WM_CLOSE / RM restart); the daemons get 1
         because they have no message loop to close. Everything runs as the installing user,
         so no elevation is involved. -->
    <util:CloseApplication Id="CloseGpgFrontend" Target="GpgFrontend.exe"
                           CloseMessage="yes" TerminateProcess="0" RebootPrompt="no" />
    <util:CloseApplication Id="CloseGpgAgent" Target="gpg-agent.exe"
                           TerminateProcess="1" RebootPrompt="no" />
    <util:CloseApplication Id="CloseKeyboxd" Target="keyboxd.exe"
                           TerminateProcess="1" RebootPrompt="no" />
    <util:CloseApplication Id="CloseDirmngr" Target="dirmngr.exe"
                           TerminateProcess="1" RebootPrompt="no" />
    <util:CloseApplication Id="CloseScdaemon" Target="scdaemon.exe"
                           TerminateProcess="1" RebootPrompt="no" />

    <!-- MsiLaunchConditionsComponent, 6 rows: requires NT (blocks 9x), requires x64 on NT,
         blocks NT4 (400), 2000 (500), XP/2003 (501/502) and Vista/2008 (600).
         Net requirement: 64-bit Windows 7 or later. -->
    <Launch
      Condition="Installed OR (VersionNT64 AND VersionNT &gt;= 601)"
      Message="[ProductName] can only be installed on 64-bit Windows 7 or later." />

    <!-- MsiPropsComponent: ARP* rows -->
    <Property Id="ARPCOMMENTS" Value="A modern, cross-platform OpenPGP tool with a dual-engine core: switch freely between battle-tested GnuPG and a memory-safe Rust rPGP backend. Makes encryption, signing, and key management simple and trustworthy." />
    <Property Id="ARPCONTACT" Value="eric@bktus.com" />
    <Property Id="ARPHELPLINK" Value="https://www.gpgfrontend.bktus.com/overview/glance" />
    <Property Id="ARPURLINFOABOUT" Value="https://www.gpgfrontend.bktus.com/overview/contact" />
    <Property Id="ARPURLUPDATEINFO" Value="https://gpgfrontend.bktus.com/overview/downloads" />
    <!-- ARPNOMODIFY=1 is contributed by WixUI_InstallDir below, matching the AIP. -->
    <Property Id="ARPPRODUCTICON" Value="gpgfrontend.exe" />

    <!-- MsiIconsComponent: icon key "gpgfrontend.exe", SourcePath "gpgfrontend.ico"
         relative to the AIP root (NOT the copy inside the payload's bin\). -->
    <Icon Id="gpgfrontend.exe" SourceFile="$(IconSource)" />

    <!-- AI_RESTORE_LOCATION (UI seq 749, condition APPDIR=""): re-read the install dir a
         previous version stored in the registry, unless one was passed on the command line. -->
    <Property Id="PREVIOUSINSTALLFOLDER">
      <RegistrySearch Id="PreviousInstallFolder" Root="HKCU"
                      Key="Software\Saturneric\GpgFrontend" Name="Path" Type="raw" />
    </Property>
    <SetDirectory Id="INSTALLFOLDER" Value="[PREVIOUSINSTALLFOLDER]"
                  Condition="PREVIOUSINSTALLFOLDER AND NOT INSTALLFOLDER" />

    <!-- AI_STORE_LOCATION: ARPINSTALLLOCATION = [APPDIR] -->
    <SetProperty Id="ARPINSTALLLOCATION" Value="[INSTALLFOLDER]" After="CostFinalize" Sequence="execute" />

    <!-- MsiDirsComponent: APPDIR -> [AppDataFolder]\GpgFrontend (SET_APPDIR, DefaultBuild).
         The bin\ / modules\ / gnupg\... subtree (~50 Directory rows) is regenerated by
         the <Files> harvest below. -->
    <StandardDirectory Id="AppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="GpgFrontend" />
    </StandardDirectory>

    <!-- MsiFilesComponent + MsiCompsComponent + MsiFeatCompsComponent + SideBySideGuidComponent:
         189 files, one component per file, all in MainFeature. <Files> reproduces exactly that
         (one component with a stable generated GUID per file, tree preserved).
         The AIP's fake file versions (65535.65535.65535.65535, AI's overwrite-always trick) are
         unnecessary here: RemoveExistingProducts runs early (afterInstallValidate), so upgrades
         always lay down fresh files.
         bin\ENV.ini exists on disk but is NOT in the AIP's file table — excluded to stay equal.
         Delete the Exclude line if it should ship. -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(PayloadDir)\**">
        <Exclude Files="$(PayloadDir)\bin\ENV.ini" />
      </Files>
    </ComponentGroup>

    <!-- MsiCompsComponent "ProductInformation" {B5718CF9-...}, Attributes 260
         (registry keypath + x64), KeyPath="Version" + MsiRegsComponent rows.
         Root -1 = HKMU (per-user build -> HKCU). -->
    <ComponentGroup Id="ProductInformation" Directory="INSTALLFOLDER">
      <Component Id="ProductInformation" Guid="{B5718CF9-F3A3-43B0-BE3A-DEF48CA19E0A}">
        <RegistryKey Root="HKMU" Key="Software\[Manufacturer]\[ProductName]">
          <RegistryValue Name="Path" Type="string" Value="[INSTALLFOLDER]" />
          <RegistryValue Name="Version" Type="string" Value="[ProductVersion]" KeyPath="yes" />
        </RegistryKey>
      </Component>
    </ComponentGroup>

    <!-- MsiCompsComponent "APPDIR" {6F8D11AA-...}: one component that (a) creates the install
         folder even if empty and removes it on uninstall (MsiCreateFolderComponent,
         ManualDelete="true"), and (b) owns the desktop shortcut (MsiShortsComponent
         "GpgFrontend_1": non-advertised, WkDir=PersonalFolder, Icon gpgfrontend.exe, ShowCmd 1).
         Keypath is the directory itself, exactly as in the AIP (expect benign ICE38/ICE57
         validation warnings — the Advanced Installer build carries the same table content). -->
    <ComponentGroup Id="AppDirComponent">
      <Component Id="APPDIR" Guid="{6F8D11AA-3B0C-4695-8C6A-622C60768DA7}" Directory="INSTALLFOLDER">
        <CreateFolder />
        <RemoveFolder Id="RemoveINSTALLFOLDER" On="uninstall" />
        <Shortcut Id="GpgFrontend_1"
                  Directory="DesktopFolder"
                  Name="GpgFrontend"
                  Description="A modern &quot;Enigma&quot; built on GnuPG. It brings easy and trustworthy to your privacy life."
                  Target="[INSTALLFOLDER]bin\GpgFrontend.exe"
                  WorkingDirectory="PersonalFolder"
                  Icon="gpgfrontend.exe"
                  IconIndex="0"
                  Show="normal" />
      </Component>
    </ComponentGroup>

    <!-- MsiFeatsComponent: single feature, literal Title/Description from the AIP,
         Display 1 (expanded), Level 1, configurable directory APPDIR. -->
    <Feature Id="MainFeature"
             Title="MainFeature"
             Description="Description"
             Display="expand"
             Level="1"
             ConfigurableDirectory="INSTALLFOLDER">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="ProductInformation" />
      <ComponentGroupRef Id="AppDirComponent" />
    </Feature>

    <!-- MsiThemeComponent "classic" + FragmentComponent (WelcomeDlg, FolderDlg,
         MaintenanceWelcome/TypeDlg, VerifyRemove/RepairDlg — note: NO license dialog).
         WixUI_InstallDir is the equivalent stock dialog set; the two Publish overrides
         skip its LicenseAgreementDlg to match the AIP's Welcome -> Folder flow. -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- Branding art, replacing the stock WixUIExtension bitmaps (red sidebar, generic
         disc glyph). Both are 24-bit BMPs generated from the app icon by
         make_ui_bitmaps.py in this folder; re-run it if the icon changes.
           WixUIDialogBmp 493x312 -> WelcomeDlg / ExitDlg background
           WixUIBannerBmp 493x58  -> top banner of the remaining dialogs -->
    <WixVariable Id="WixUIDialogBmp" Value="$(BrandingDir)\dialog.bmp" />
    <WixVariable Id="WixUIBannerBmp" Value="$(BrandingDir)\banner.bmp" />

    <UI>
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg" Order="2" Condition="NOT Installed" />
      <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2" Condition="NOT Installed" />
    </UI>

  </Package>
</Wix>
